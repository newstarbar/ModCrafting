{
	"name": "modcrafting",
	"type": "module",
	"version": "1.0.0",
	"description": "A one-stop Minecraft mod development environment based on Vibecoding 基于Vibecoding的一站式Minecraft模组开发环境",
	"author": "newstarbar",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"start": "electron .",
		"build:win": "electron-vite build && node scripts/run-electron-builder.mjs --win nsis && node scripts/run-electron-builder.mjs --config electron-builder.portable.json --win portable",
		"build:win:setup": "electron-vite build && node scripts/run-electron-builder.mjs --win nsis",
		"build:win:portable": "electron-vite build && node scripts/run-electron-builder.mjs --config electron-builder.portable.json --win portable",
		"render:manifest": "node scripts/render-update-manifest.mjs",
		"render:release-notes": "node scripts/render-release-notes.mjs",
		"sync:gitee": "node scripts/sync-gitee-release.mjs",
		"push:gitee": "node scripts/push-gitee-git.mjs",
		"setup:toolchain": "node scripts/setup-toolchain.mjs",
		"prefetch:deps": "node scripts/prefetch-fabric-deps.mjs",
		"verify:toolchain": "node scripts/verify-toolchain.mjs",
		"verify:offline": "node scripts/verify-offline-build.mjs",
		"generate:icon": "node scripts/generate-icon-ico.mjs",
		"postinstall": "node scripts/ensure-native-deps.mjs",
		"prebuild:win": "node scripts/generate-icon-ico.mjs && node scripts/setup-toolchain.mjs && node scripts/prefetch-fabric-deps.mjs && node scripts/patch-nsis-install-ui.mjs",
		"prebuild:win:setup": "node scripts/generate-icon-ico.mjs && node scripts/setup-toolchain.mjs && node scripts/prefetch-fabric-deps.mjs && node scripts/patch-nsis-install-ui.mjs",
		"prebuild:win:portable": "node scripts/generate-icon-ico.mjs && node scripts/verify-portable-resources.mjs"
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"electron-updater": "^6.6.2",
		"iconv-lite": "^0.7.2",
		"node-pty": "^1.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react": "^6.0.2",
		"electron": "^42.4.1",
		"electron-builder": "^26.0.0",
		"electron-vite": "^6.0.0-beta.1",
		"png-to-ico": "^3.0.1",
		"sharp": "^0.35.2",
		"typescript": "^5.8.3",
		"vite": "^8.0.16"
	},
	"build": {
		"extends": "./electron-builder.base.json",
		"extraResources": [
			{
				"from": "resources/jdk-21",
				"to": "jdk-21",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "resources/gradle-9.5",
				"to": "gradle-9.5",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "resources/gradle-wrapper.jar",
				"to": "gradle-wrapper.jar"
			},
			{
				"from": "resources/gradle-home-seed",
				"to": "gradle-home-seed",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "resources/fabric-versions.json",
				"to": "fabric-versions.json"
			},
			{
				"from": "build/appIcon.png",
				"to": "icon.png"
			},
			{
				"from": "resources/_base_mods",
				"to": "_base_mods",
				"filter": [
					"**/*.jar"
				]
			}
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "build/appIcon.ico",
			"signExecutable": false
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"allowElevation": true,
			"perMachine": false,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"menuCategory": true,
			"shortcutName": "ModCrafting",
			"runAfterFinish": true,
			"deleteAppDataOnUninstall": false,
			"displayLanguageSelector": true,
			"installerLanguages": [
				"zh_CN",
				"en_US"
			],
			"language": "2052",
			"include": "build/installer.nsh",
			"installerIcon": "build/installerIcon.ico",
			"installerHeaderIcon": "build/installerIcon.ico",
			"guid": "c8f4a2b1-9e3d-4f5a-b6c7-8d9e0f1a2b3c",
			"artifactName": "${productName} Setup ${version}.${ext}",
			"uninstallDisplayName": "ModCrafting",
			"warningsAsErrors": false
		}
	},
	"publish": [
		{
			"provider": "github",
			"owner": "newstarbar",
			"repo": "ModCrafting",
			"draft": false,
			"releaseInfo": {
				"releaseNotesFile": "build/release-body.md"
			}
		}
	],
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/newstarbar/ModCrafting.git"
	},
	"allowScripts": {
		"electron@42.4.1": true,
		"node-pty@1.1.0": true,
		"sharp@0.35.2": true,
		"esbuild@0.25.12": true,
		"electron-winstaller@5.4.0": true
	}
}
