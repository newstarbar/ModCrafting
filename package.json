{
	"name": "modcrafting",
	"type": "module",
	"version": "1.0.0",
	"description": "A one-stop Minecraft mod development environment based on Vibecoding 基于Vibecoding的一站式Minecraft模组开发环境",
	"author": "newstarbar",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"start": "electron .",
		"test": "node scripts/test/run-harness.mjs",
		"test:harness": "npm run test",
		"build:win": "electron-vite build && node scripts/packaging/run-electron-builder.mjs --win nsis && node scripts/packaging/run-electron-builder.mjs --config electron-builder.portable.json --win portable",
		"build:win:setup": "electron-vite build && node scripts/packaging/run-electron-builder.mjs --win nsis",
		"build:win:portable": "electron-vite build && node scripts/packaging/run-electron-builder.mjs --config electron-builder.portable.json --win portable",
		"prebuild:win": "node scripts/prebuild-win.mjs --target full",
		"prebuild:win:setup": "node scripts/prebuild-win.mjs --target full",
		"prebuild:win:portable": "node scripts/prebuild-win.mjs --target portable",
		"toolchain:setup": "node scripts/toolchain/setup-toolchain.mjs",
		"toolchain:verify": "node scripts/toolchain/verify-toolchain.mjs",
		"toolchain:prefetch": "node scripts/toolchain/prefetch-fabric-deps.mjs",
		"toolchain:verify-offline": "node scripts/toolchain/verify-offline-build.mjs",
		"toolchain:symbol-index": "node scripts/toolchain/generate-fabric-symbol-index.mjs",
		"assets:prepare": "python scripts/assets/prepare_renderer_assets.py",
		"assets:mc": "python scripts/assets/ensure_minecraft_assets.py",
		"assets:items": "python scripts/assets/generate_items.py",
		"assets:icon": "node scripts/assets/generate-icon-ico.mjs",
		"release:manifest": "node scripts/release/render-update-manifest.mjs",
		"release:notes": "node scripts/release/render-release-notes.mjs",
		"release:push-gitee": "node scripts/release/push-gitee-git.mjs",
		"release:sync-gitee": "node scripts/release/sync-gitee-release.mjs",
		"release:cleanup-github": "node scripts/release/cleanup-github-release.mjs",
		"clean:local": "node scripts/clean-local.mjs",
		"docs:sync-fabric": "node --experimental-strip-types scripts/sync-fabric-docs-knowledge.ts",
		"docs:prefetch-fabric": "npm run docs:sync-fabric",
		"setup:toolchain": "npm run toolchain:setup",
		"prefetch:deps": "npm run toolchain:prefetch",
		"verify:toolchain": "npm run toolchain:verify",
		"verify:offline": "npm run toolchain:verify-offline",
		"generate:fabric-index": "npm run toolchain:symbol-index",
		"prepare:renderer-assets": "npm run assets:prepare",
		"prefetch:mc-assets": "npm run assets:mc",
		"generate:items": "npm run assets:items",
		"generate:icon": "npm run assets:icon",
		"render:manifest": "npm run release:manifest",
		"render:release-notes": "npm run release:notes",
		"sync:gitee": "npm run release:sync-gitee",
		"push:gitee": "npm run release:push-gitee",
		"postinstall": "node scripts/lib/ensure-native-deps.mjs"
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"@fontsource/press-start-2p": "^5.2.7",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"ajv": "^8.20.0",
		"electron-updater": "^6.6.2",
		"iconv-lite": "^0.7.2",
		"node-pty": "^1.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react": "^6.0.2",
		"electron": "^42.4.1",
		"electron-builder": "^26.0.0",
		"electron-vite": "^6.0.0-beta.1",
		"png-to-ico": "^3.0.1",
		"sharp": "^0.35.2",
		"typescript": "^5.8.3",
		"vite": "^8.0.16"
	},
	"optionalDependencies": {
		"@opencode-ai/sdk": "^1.17.18",
		"opencode-ai": "^1.17.18"
	},
	"build": {
		"extends": "./electron-builder.base.json",
		"extraResources": [
			{
				"from": "resources/jdk-21",
				"to": "jdk-21",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "resources/gradle-9.5",
				"to": "gradle-9.5",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "resources/gradle-wrapper.jar",
				"to": "gradle-wrapper.jar"
			},
			{
				"from": "resources/gradle-home-seed.zip",
				"to": "gradle-home-seed.zip"
			},
			{
				"from": "resources/fabric-versions.json",
				"to": "fabric-versions.json"
			},
			{
				"from": "resources/fabric-symbol-index-1.21.4.json.gz",
				"to": "fabric-symbol-index-1.21.4.json.gz"
			},
			{
				"from": "resources/agent-knowledge",
				"to": "agent-knowledge",
				"filter": [
					"**/*.md"
				]
			},
			{
				"from": "packaging/appIcon.png",
				"to": "icon.png"
			},
			{
				"from": "resources/_base_mods",
				"to": "_base_mods",
				"filter": [
					"**/*.jar"
				]
			}
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "packaging/appIcon.ico",
			"signExecutable": false
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"allowElevation": false,
			"perMachine": false,
			"createDesktopShortcut": false,
			"createStartMenuShortcut": false,
			"menuCategory": true,
			"shortcutName": "ModCrafting",
			"runAfterFinish": true,
			"deleteAppDataOnUninstall": false,
			"displayLanguageSelector": false,
			"language": "2052",
			"license": "packaging/license_zh_CN.txt",
			"installerSidebar": "packaging/installerSidebar.bmp",
			"installerHeader": "packaging/installerHeader.bmp",
			"uninstallerSidebar": "packaging/uninstallerSidebar.bmp",
			"include": "packaging/installer.nsh",
			"installerIcon": "packaging/installerIcon.ico",
			"installerHeaderIcon": "packaging/installerIcon.ico",
			"uninstallerIcon": "packaging/installerIcon.ico",
			"guid": "c8f4a2b1-9e3d-4f5a-b6c7-8d9e0f1a2b3c",
			"artifactName": "${productName} Setup ${version}.${ext}",
			"uninstallDisplayName": "ModCrafting",
			"warningsAsErrors": false
		}
	},
	"publish": [
		{
			"provider": "github",
			"owner": "newstarbar",
			"repo": "ModCrafting",
			"draft": false,
			"releaseInfo": {
				"releaseNotesFile": "packaging/release-body.md"
			}
		}
	],
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/newstarbar/ModCrafting.git"
	},
	"allowScripts": {
		"electron@42.4.1": true,
		"node-pty@1.1.0": true,
		"sharp@0.35.2": true,
		"esbuild@0.25.12": true,
		"electron-winstaller@5.4.0": true
	}
}
